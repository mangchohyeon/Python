{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Python 디버거: 현재 파일",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd" : "C:/Users/PC/Desktop/Coding/Python/Code"
    },

    {
      "name":"(gdb)시작",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\MinGW\\bin\\gdb.exe",
      "targetArchitecture": "x86_64",
      "setupCommands": [
          {
              "description": "gdb에 자동 서식 지정 사용",
              "text": "-enable-pretty-printing",
              "ignoreFailures": true
          }
      ]
    }
    
  ]

}